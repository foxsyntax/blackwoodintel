---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_URL } from '../consts';

type Props = CollectionEntry<'analysis'>['data'] & { readingTime?: number };

const { title, number, description, pubDate, updatedDate, status, readingTime } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE_URL).href;

const closingDate = pubDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description ?? '',
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  url: canonicalURL,
  publisher: {
    '@type': 'Organization',
    name: 'Blackwood Intelligence',
    url: SITE_URL,
  },
  author: {
    '@type': 'Organization',
    name: 'Blackwood Intelligence',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} type="article" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Header />
    <main>
      <article>
        <header class="article-header">
          <span class="article-id">Blackwood Analysis {number}</span>
          <h1 class="article-title">{title}</h1>
          {description && <p class="article-subtitle">{description}</p>}
          <div class="article-meta">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <>
                <span>·</span>
                <span>Updated <FormattedDate date={updatedDate} /></span>
              </>
            )}
            <span>·</span>
            <span>{status}</span>
            {readingTime && (
              <>
                <span>·</span>
                <span>~{readingTime} min read</span>
              </>
            )}
          </div>
        </header>

        <div class="prose">
          <slot />
        </div>
      </article>

      <hr style="margin-top: 3rem;" />
      <div style="padding: 1.5rem 0 0; font-family: var(--font-sans);">
        <p style="font-size: 0.78rem; color: var(--text-muted); letter-spacing: 0.04em; margin-bottom: 0.75rem;">
          Blackwood Analysis {number} — {closingDate}
        </p>
        <a href="/analysis" style="font-size: 0.8rem; color: var(--text-muted);">← Analysis</a>
      </div>
    </main>
    <Footer />
  </body>
</html>
