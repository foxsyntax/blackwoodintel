---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_URL } from '../consts';

type Props = CollectionEntry<'anatomy'>['data'];

const {
  title,
  number,
  caseFile,
  event,
  structuralPathogen,
  failureClass,
  pubDate,
  typeTag,
  lede,
  pathogens,
  structure,
} = Astro.props;

const pubMonth = pubDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE_URL).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: lede,
  datePublished: pubDate.toISOString(),
  url: canonicalURL,
  publisher: { '@type': 'Organization', name: 'Blackwood Intelligence', url: SITE_URL },
  author: { '@type': 'Organization', name: 'Blackwood Intelligence' },
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={lede} type="article" />
    <!-- Anatomy-specific fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="anatomy-page">
    <Header />
    <main class="anatomy-main" style="max-width: 820px; margin: 0 auto; padding: 2.5rem 1rem 0;">

      <!-- Case file header -->
      <div class="anatomy-case-header">
        <div class="anatomy-fields">
          <div class="anatomy-field">
            <span class="anatomy-field__label">Case file</span>
            <span class="anatomy-field__value">{caseFile}</span>
          </div>
          <div class="anatomy-field">
            <span class="anatomy-field__label">Event</span>
            <span class="anatomy-field__value">{event}</span>
          </div>
          <div class="anatomy-field">
            <span class="anatomy-field__label">Structural pathogen</span>
            <span class="anatomy-field__value">{structuralPathogen}</span>
          </div>
          <div class="anatomy-field">
            <span class="anatomy-field__label">Failure class</span>
            <span class="anatomy-field__value">{failureClass}</span>
          </div>
          <div class="anatomy-field">
            <span class="anatomy-field__label">Published</span>
            <span class="anatomy-field__value">{pubMonth}</span>
          </div>
        </div>

        <div class="anatomy-title-block">
          <span class="anatomy-type-tag">{typeTag}</span>
          <h1 class="anatomy-title" set:html={title} />
          <p class="anatomy-lede">{lede}</p>
          {pathogens.length > 0 && (
            <div class="anatomy-pathogens">
              {pathogens.map((p) => (
                <span class="anatomy-pathogen">{p}</span>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- Structure map -->
      {structure.length > 0 && (
        <div class="anatomy-structure-map">
          <span class="anatomy-map-label">Document structure</span>
          <div class="anatomy-map-grid" style={`grid-template-columns: repeat(${Math.min(structure.length, 5)}, 1fr);`}>
            {structure.map((s) => (
              <div class="anatomy-map-cell">
                <span class="anatomy-map-num">{s.num}</span>
                <span class="anatomy-map-title">{s.title}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Article body (MDX sections) -->
      <div class="anatomy-body">
        <slot />
      </div>

      <!-- Footer row -->
      <div class="anatomy-footer-row">
        <div></div>
        <div class="anatomy-footer-body">
          <span class="anatomy-footer-text">blackwoodintel.com</span>
          <span class="anatomy-footer-text">{caseFile} · {failureClass} · {pubMonth}</span>
        </div>
      </div>

      <!-- Back link -->
      <div style="padding: 2.5rem 0 1rem; grid-column: 2;">
        <a href="/anatomy" style="font-family: var(--font-sans); font-size: 0.8rem; color: var(--text-muted);">← Anatomy</a>
      </div>

    </main>
    <Footer />
  </body>
</html>
