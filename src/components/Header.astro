---
import { SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/analysis', label: 'Analysis' },
  { href: '/signals', label: 'Signals' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header">
  <a href="/" class="site-header__wordmark">{SITE_TITLE}</a>
  <p class="site-header__tagline">
    Independent forensic analysis of systems, power, and collapse.
  </p>
</header>

<div class="site-nav-wrapper">
  <nav class="site-nav" aria-label="Primary navigation">
    <ul class="site-nav__links">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a href="mailto:analysis@blackwoodintel.com" class="site-nav__contact">
      analysis@blackwoodintel.com
    </a>
  </nav>
</div>
