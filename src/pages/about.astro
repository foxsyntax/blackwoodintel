---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="About"
      description="Blackwood Intelligence conducts forensic analysis of power, incentives, and systemic collapse."
    />
  </head>
  <body>
    <Header />
    <main>

      <h1 class="sr-only">About — Blackwood Intelligence</h1>

      <hr class="heavy" style="margin-top: 0; margin-bottom: 3rem;" />

      <!-- Opening -->
      <div class="about-opening">
        <p class="about-lead">
          Blackwood Intelligence conducts forensic analysis of power, incentives, and systemic collapse.
        </p>
        <p class="about-sub">
          Our work focuses on how systems behave under pressure, particularly when structure
          and reality begin to diverge.
        </p>
      </div>

      <!-- Dossier sections -->
      <div class="about-body">

        <div class="about-row">
          <span class="about-row__label">Positioning</span>
          <div class="about-row__content">
            <p>Blackwood operates as a small, independent desk. It publishes analysis publicly
            and undertakes a limited number of private engagements.</p>
            <p>We work with a limited number of partners.</p>
          </div>
        </div>

        <div class="about-row">
          <span class="about-row__label">Method</span>
          <div class="about-row__content">
            <p>Analysis begins with structural questions. Each piece traces incentives, constraints,
            and information flows to identify where systems behave inconsistently with their
            apparent design.</p>
            <p>Where evidence is incomplete, uncertainty is stated explicitly.</p>
          </div>
        </div>

        <div class="about-row">
          <span class="about-row__label">Signals</span>
          <div class="about-row__content">
            <p>Signals record shorter observations: early indicators, structural tensions,
            and anomalies that do not yet warrant full analysis.</p>
          </div>
        </div>

        <div class="about-row">
          <span class="about-row__label">What Blackwood<br />Is Not</span>
          <div class="about-row__content">
            <p>Blackwood is not a think tank.</p>
            <p>It does not produce commentary, advocacy, or narrative-driven analysis.</p>
            <p>It does not represent any institution, government, or financial interest.</p>
          </div>
        </div>

        <div class="about-row about-row--contact">
          <span class="about-row__label">Contact</span>
          <div class="about-row__content">
            <div class="about-contact-links">
              <a href="mailto:analysis@blackwoodintel.com">analysis@blackwoodintel.com</a>
              <a href="https://t.me/blackwoodintel" target="_blank" rel="noopener noreferrer">Telegram: @blackwoodintel</a>
            </div>
          </div>
        </div>

      </div>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* ── Opening block ── */
  .about-opening {
    margin-bottom: 3.5rem;
  }

  .about-lead {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--text-primary);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .about-sub {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 0;
  }

  /* ── Dossier grid ── */
  .about-body {
    display: flex;
    flex-direction: column;
  }

  .about-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 2.5rem;
    align-items: start;
    border-top: 1px solid var(--gray-200);
    padding: 1.75rem 0 2rem;
  }

  /* ── Row label ── */
  .about-row__label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--text-muted);
    line-height: 1.5;
    padding-top: 0.2rem;
  }

  /* ── Row content ── */
  .about-row__content p {
    font-family: var(--font-serif);
    font-size: 0.9875rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 0.9em;
  }

  .about-row__content p:last-child {
    margin-bottom: 0;
  }

  /* ── Contact ── */
  .about-contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
  }

  .about-contact-links a {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--gray-200);
    width: fit-content;
    padding-bottom: 1px;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .about-contact-links a:hover {
    color: var(--black);
    border-bottom-color: var(--black);
  }

  /* ── Mobile ── */
  @media (max-width: 580px) {
    .about-row {
      grid-template-columns: 1fr;
      gap: 0.6rem;
      padding: 1.5rem 0 1.75rem;
    }

    .about-row__label {
      padding-top: 0;
    }
  }
</style>
