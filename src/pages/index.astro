---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const analyses = (await getCollection('analysis'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const signals = (await getCollection('signals'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <h1 class="sr-only">Blackwood Intelligence</h1>

      <!-- Analysis -->
      <section>
        <h2 class="section-heading">Analysis</h2>
        <hr class="heavy" />

        {analyses.length === 0 ? (
          <p style="color: var(--text-muted); padding: 2rem 0;">No analyses published yet.</p>
        ) : (
          <ul class="analysis-list">
            {analyses.map((post) => (
              <li class="analysis-item">
                <div class="analysis-item__meta">
                  <span class="analysis-item__number">Analysis {post.data.number}</span>
                  <span class="analysis-item__date-small">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                </div>
                <div class="analysis-item__body">
                  <a href={`/analysis/${post.id}/`} class="analysis-item__title">
                    {post.data.title}
                  </a>
                  {post.data.description && (
                    <p class="analysis-item__excerpt">{post.data.description}</p>
                  )}
                  <a href={`/analysis/${post.id}/`} class="analysis-item__read">Read &rarr;</a>
                </div>
              </li>
            ))}
          </ul>
        )}

        <p style="margin-top: 1.75rem; font-size: 0.82rem;">
          <a href="/analysis">View archive &rarr;</a>
        </p>
      </section>

      <hr style="margin: 3rem 0;" />

      <!-- Signals -->
      <section>
        <h2 class="section-heading">Signals</h2>
        <hr class="heavy" />

        {signals.length === 0 ? (
          <p style="color: var(--text-muted); padding: 2rem 0;">No signals published yet.</p>
        ) : (
          <ul class="signals-list">
            {signals.map((signal) => {
              const num = signal.id.split('-')[0];
              const prefix = `Signal ${num}`;
              return (
                <li class="signal-item">
                  <div class="signal-item__date">
                    <span class="signal-item__prefix">{prefix}</span>
                    <span class="signal-item__date-text">
                      <FormattedDate date={signal.data.pubDate} />
                    </span>
                  </div>
                  <div class="signal-item__body">
                    <p class="signal-item__content">{signal.body}</p>
                  </div>
                </li>
              );
            })}
          </ul>
        )}

        <p style="margin-top: 1.75rem; font-size: 0.82rem;">
          <a href="/signals">View all signals &rarr;</a>
        </p>
      </section>

    </main>
    <Footer />
  </body>
</html>
