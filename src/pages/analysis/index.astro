---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const analyses = (await getCollection('analysis'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Analysis"
      description="Long-form forensic research on power, money, and systemic collapse. Published by Blackwood Intelligence."
    />
  </head>
  <body>
    <Header />
    <main>

      <h1 class="section-heading" style="font-size: 1.9rem;">Analysis</h1>
      <hr class="heavy" style="margin-top: 1.25rem;" />

      {analyses.length === 0 ? (
        <p style="color: var(--text-muted); padding: 3rem 0;">
          The first analysis is being prepared. Check back soon.
        </p>
      ) : (
        <ul class="analysis-list">
          {analyses.map((post) => (
            <li class="analysis-item">
              <div class="analysis-item__meta">
                <span class="analysis-item__number">Analysis {post.data.number}</span>
                <span class="analysis-item__date-small">
                  <FormattedDate date={post.data.pubDate} />
                </span>
                <span class="analysis-item__date-small" style="margin-top: 0.1rem; color: var(--gray-400);">
                  {post.data.status}
                </span>
              </div>
              <div class="analysis-item__body">
                <a href={`/analysis/${post.id}/`} class="analysis-item__title">
                  {post.data.title}
                </a>
                {post.data.description && (
                  <p class="analysis-item__excerpt">{post.data.description}</p>
                )}
                <a href={`/analysis/${post.id}/`} class="analysis-item__read">Read &rarr;</a>
              </div>
            </li>
          ))}
        </ul>
      )}

    </main>
    <Footer />
  </body>
</html>
