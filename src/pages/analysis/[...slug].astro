---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import AnalysisPost from '../../layouts/AnalysisPost.astro';

export async function getStaticPaths() {
  const analyses = await getCollection('analysis');
  return analyses.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<'analysis'>;

const post = Astro.props;
const { Content } = await render(post);

// Estimate reading time (~200 wpm for dense analytical content)
const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<AnalysisPost {...post.data} readingTime={readingTime}>
  <Content />
</AnalysisPost>
