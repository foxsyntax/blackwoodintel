---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const cases = (await getCollection('anatomy'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Anatomy"
      description="Blackwood intellectual autopsies of systemic failures, strategic collapses, and irreversible conditions."
    />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>

      <h1 class="section-heading" style="font-size: 1.9rem;">Anatomy</h1>
      <hr class="heavy" style="margin-top: 1.25rem; margin-bottom: 1.75rem;" />

      <div class="anatomy-intro">
        <p class="anatomy-intro__headline">
          Blackwood intellectual autopsies of systemic failures, strategic collapses, and irreversible conditions.
        </p>
        <p class="anatomy-intro__sub">
          Focused not on narrative reconstruction, but on the hidden architectures that made collapse possible.
        </p>
      </div>

      {cases.length === 0 ? (
        <p style="color: var(--text-muted); padding: 3rem 0;">No case studies published yet.</p>
      ) : (
        <ul class="anatomy-list">
          {cases.map((c) => (
            <li class="anatomy-list-item">
              <div class="anatomy-list-item__meta">
                <span class="anatomy-list-item__id">{c.data.caseFile}</span>
                <span class="anatomy-list-item__date">
                  <FormattedDate date={c.data.pubDate} />
                </span>
              </div>
              <div class="anatomy-list-item__body">
                <a href={`/anatomy/${c.id}/`} class="anatomy-list-item__title">
                  {c.data.title}
                </a>
                <span class="anatomy-list-item__event">{c.data.event}</span>
                <span class="anatomy-list-item__pathogen">{c.data.structuralPathogen}</span>
                {c.data.pathogens.length > 0 && (
                  <div class="anatomy-list-item__tags">
                    {c.data.pathogens.slice(0, 4).map((p) => (
                      <span class="anatomy-list-item__tag">{p}</span>
                    ))}
                  </div>
                )}
              </div>
            </li>
          ))}
        </ul>
      )}

    </main>
    <Footer />
  </body>
</html>
